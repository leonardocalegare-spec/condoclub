# MongoDB Connection
# Local: mongodb://localhost:27017
# Atlas: mongodb+srv://USER:PASSWORD@cluster.mongodb.net/condoclub?retryWrites=true&w=majority
MONGO_URL=mongodb://localhost:27017
DB_NAME=condoclub

# JWT Secret - CHANGE THIS IN PRODUCTION!
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=condoclub-secret-key-change-in-production

# MercadoPago (leave empty for sandbox mode)
# Get credentials: https://www.mercadopago.com.br/developers/panel
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_WEBHOOK_SECRET=

# App URL (for payment redirects)
APP_URL=https://your-frontend-domain.com

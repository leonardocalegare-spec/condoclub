# Copy this file to .env and fill in the values
# cp backend/.env.example backend/.env

# PostgreSQL connection string
DATABASE_URL="postgresql://condoclub:condoclub123@localhost:5432/condoclub"

# JWT signing secret — use a random string of at least 32 characters in production
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-chars"

# Token expiry (e.g. 7d, 24h, 1h)
JWT_EXPIRES_IN="7d"

# Port the Express API listens on
PORT=3001

# Node environment: development | test | production
NODE_ENV=development
